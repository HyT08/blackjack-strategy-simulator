import blackjack
from tqdm import tqdm

sim = blackjack.Simulation(performance_mode=True, bankroll=1000000, finite_deck=False)

def strategy():
    sim.bet(500)
    if sim.calculate_value(sim.get_player_hand()) > 18:
       sim.hit()
    else: sim.stand()


for i in range(10):
    for i in tqdm(range(100000)):
        sim.run(strategy)
    print(f'Bankroll: {sim.bankroll}')
    sim._reset_bankroll()
print('Finished')
print(f'EV: {sim.get_player_ev()}')
print(f'Winrate: {sim.get_win_prob(sim.player_wins)}')