import sys
import os
sys.path.append(os.path.abspath("../src"))
import strategies
import blackjack
import monte_carlo

#Configure the parameters for the blackjack game:
simulation = blackjack.Simulation(performance_mode=True, finite_deck=True, 
                           num_of_decks=6, penetration=0.8 , 
                           bets_active=True, bankroll=10000, 
                           dealer_hit_17=True, blackjack_payout=1.5)
#Choose the strategy to simulate with:
strategy = strategies.Example()

#Configure the Parameters for the Monte Carlo Simulation:
monte_carlo.monte_carlo(simulation, strategy, mc_runs=100, bj_rounds=1000, plot=True, plot_points=500)
